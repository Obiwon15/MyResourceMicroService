{
  "app": {
    "name": "employee-service"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "mongo": {
    "connectionString": "mongodb://localhost:27017",
    "databaseName": "employee-service",
    "seed": false
  },
  "consul": {
    "enabled": true,
    "url": "http://localhost:8500",
    "service": "customers-service",
    "address": "docker.for.mac.localhost",
    "port": "5022",
    "pingEnabled": false,
    "pingEndpoint": "ping",
    "pingInterval": 5,
    "removeAfterInterval": 10,
    "requestRetries": 3
  },
  "fabio": {
    "enabled": true,
    "url": "http://localhost:9999",
    "service": "customers-service",
    "requestRetries": 3
  },
  "elk": {
    "enabled": true,
    "url": "http://localhost:9200",
    "indexFormat": "Employee-service-{0:yyyy.MM.dd}",
    "basicAuthEnabled": false,
    "username": "user",
    "password": "secret"
  },
  "jaeger": {
    "enabled": true,
    "serviceName": "employee",
    "udpHost": "localhost",
    "udpPort": 6831,
    "maxPacketSize": 0,
    "sampler": "const"
  },
  "rabbitMq": {
    "namespace": "employee",
    "retries": 3,
    "retryInterval": 2,
    "username": "guest",
    "password": "guest",
    "virtualHost": "/",
    "port": 5672,
    "hostnames": [
      "rabbitmq"
    ],
    "requestTimeout": "00:00:10",
    "publishConfirmTimeout": "00:00:01",
    "recoveryInterval": "00:00:10",
    "persistentDeliveryMode": true,
    "autoCloseConnection": true,
    "automaticRecovery": true,
    "topologyRecovery": true,
    "exchange": {
      "durable": true,
      "autoDelete": false,
      "type": "Topic"
    },
    "queue": {
      "autoDelete": false,
      "durable": true,
      "exclusive": false
    }
  },
  "serilog": {
    "consoleEnabled": true,
    "level": "information"
  },
  "seq": {
    "enabled": true,
    "url": "http://localhost:5341",
    "token": "secret"
  },
  "restEase": {
    "loadBalancer": "consul",
    "services": [
      {
        "name": "authentication-service",
        "host": "localhost",
        "scheme": "http",
        "port": "5010"
      },
      {
        "name": "appraisal-service",
        "host": "localhost",
        "scheme": "http",
        "port": "5002"
      }
    ]
  }

}
